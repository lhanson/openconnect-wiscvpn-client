#!/usr/bin/env bash

usage() {
	echo "Usage: $0 [args] [config_file_path]"
	echo "[config_file_path] defaults to \"$(default_config_path)\""
	echo
	echo "Split tunnelling arguments"
	echo "	--split		    Enable split tunneling using well-known DoIT IP ranges"
	echo "	--no-host-names Do not add either short or long hostnames to /etc/hosts"
	echo "	--no-ns-hosts   Do not add nameserver aliases to /etc/hosts (default is to name them dns0.tun0, etc.)"
}

default_config_path() {
	if [ -z "$XDG_CONFIG_HOME" ]; then
		echo "$HOME/.config/vpn/config"
	else
		echo "$XDG_CONFIG_HOME/vpn/config"
	fi
}

main() {
	local config_file
	local split_tunnel="false"
	local no_host_names="false"
	local no_ns_hosts="false"

	if [[ $EUID -ne 0 ]]; then
		echo "This script must be run as root, use sudo \"$0\" instead" 1>&2
		exit 1
	fi

	# Parse input
	if [[ $# -gt 4 ]]; then
		usage
		exit 2
	else
		# Parse arguments
		for arg in "$@"
		do
			if [[ "$arg" == "--split" ]]; then
				split_tunnel="true"
			elif [[ "$arg" == "--no-host-names" ]]; then
				no_host_names="true"
			elif [[ "$arg" == "--no-ns-hosts" ]]; then
				no_ns_hosts="true"
			else
				config_file="$arg"
			fi
		done

		# Use default config file path if unspecified
		config_file=${config_file:-$(default_config_path)}

		# Check for vpn-slice if necessary
		command -v "vpn-slice" >/dev/null 2>&1
		if [[ $? -ne 0 && "$split_tunnel" == "true" ]]; then
			echo "Error: vpn-slice is required for split tunneling, install and try again"
			echo "https://github.com/dlenski/vpn-slice"
			exit 4
		fi
	fi

	# Sourced from vpn.config
	subnets=()
	hosts=()
	tunnel_aws_regions=()

	# shellcheck source=./config.sample
	source "$config_file"

	if [[ "$split_tunnel" == "true" ]]; then
		# If AWS regions are specified, fetch CloudFront CIDRs and add them to subnets.
		# This ensures all CloudFront IPs for those regions are routed through the VPN,
		# regardless of which specific IP a CloudFront-fronted host resolves to at any moment.
		if [[ ${#tunnel_aws_regions[@]} -gt 0 ]]; then
			for cmd in curl jq; do
				if ! command -v "$cmd" >/dev/null 2>&1; then
					echo "Error: $cmd is required for AWS CloudFront routing, install and try again"
					exit 5
				fi
			done
			echo "Adding CloudFront IP ranges for AWS regions: ${tunnel_aws_regions[*]}"
			local region_filter
			region_filter=$(printf '%s\n' "${tunnel_aws_regions[@]}" | jq -Rn '[inputs]')
			local aws_json
			aws_json=$(curl -sf https://ip-ranges.amazonaws.com/ip-ranges.json) || {
				echo "Error: failed to download AWS IP ranges from ip-ranges.amazonaws.com"
				exit 7
			}
			mapfile -t aws_cidrs < <(
				echo "$aws_json" | jq -r \
					--argjson regions "$region_filter" \
					'.prefixes[] | select(.service == "CLOUDFRONT" and (.region | IN($regions[]))) | .ip_prefix'
			)
			echo "Adding ${#aws_cidrs[@]} CloudFront CIDRs to tunnel"
			subnets+=("${aws_cidrs[@]}")
		fi

		extra_args=""
		if [[ "$no_host_names" == "true" ]]; then
			extra_args="${extra_args} --no-host-names"
		fi
		if [[ "$no_ns_hosts" == "true" ]]; then
			extra_args="${extra_args} --no-ns-hosts"
		fi
		script="vpn-slice ${extra_args} --domains-vpn-dns wisc.edu ${subnets[*]} ${hosts[*]+${hosts[*]}}"
	fi

	echo "Script to run: '${script}'"
	echo
	echo "Press [CTRL+C] to stop.."

	# Background loop to refresh routes for dynamic-IP hosts (e.g. ElasticBeanstalk endpoints)
	if [[ "$split_tunnel" == "true" && ${#hosts[@]} -gt 0 ]]; then
		_refresh_host_routes() {
			# Wait for tun0 to come up
			local retries=0
			while ! ip link show tun0 &>/dev/null; do
				sleep 1
				retries=$((retries + 1))
				[[ $retries -ge 30 ]] && { echo "route-refresh: tun0 never appeared" >&2; return 1; }
			done
			echo "route-refresh: started for ${hosts[*]}"
			while true; do
				for host in "${hosts[@]}"; do
					while IFS= read -r ip; do
						if [[ -n "$ip" ]]; then ip route replace "$ip" dev tun0 2>/dev/null; fi
					done < <(dig +short "$host" | grep -E '^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$')
				done
				sleep 30
			done
		}
		_refresh_host_routes &
		_REFRESH_PID=$!
		trap '[[ -n "$_REFRESH_PID" ]] && kill "$_REFRESH_PID" 2>/dev/null' EXIT
	fi

	(echo "${password:?}"; echo 1) | openconnect \
		--user="${user:?}" \
		--usergroup=gateway \
		--passwd-on-stdin \
		--prot=gp \
		--csd-wrapper "${hipreport:?}" \
		--script="${script}" \
		--reconnect-timeout=10 \
		uwmadison.vpn.wisc.edu
}

main "$@"
